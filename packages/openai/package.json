{
  "name": "@agnost/openai",
  "version": "0.1.0",
  "description": "Agnost AI integration for OpenAI Agents SDK — wrap your OpenAI client in one line",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@agnost/core": "workspace:*",
    "@opentelemetry/api": "^1.8.0"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "devDependencies": {
    "openai": "^4.52.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
